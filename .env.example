# 2PIX 环境变量模板
# 复制本文件为 .env 并根据实际情况修改
# 注意：.env 文件不会被提交到 Git

# 服务器端口
PORT=3001

# 运行环境
NODE_ENV=development

# CORS 允许来源（生产环境必填，多个用逗号分隔）
# 示例：CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com
CORS_ORIGINS=

# JWT 密钥（生产环境必须修改！）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT 过期时间
JWT_EXPIRES_IN=7d

# 配置加密密钥（用于加密支付私钥等敏感配置，生产环境必须修改！）
CONFIG_ENCRYPTION_KEY=your-super-secret-config-encryption-key-change-this

# 默认管理员密码（仅在数据库初始化时生效）
ADMIN_DEFAULT_PASSWORD=admin123456
